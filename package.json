{
  "name": "frontend",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "Thanapat Sirisopolporn <66160064@go.buu.ac.th>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare",
    "setup-node": "powershell -Command \"$v = (Get-Content .nvmrc).Trim(); nvm install $v; nvm use $v\"",
    "setup": "npm run setup-node && npm ci",
    "prepare": "husky"
  },
  "dependencies": {
    "@quasar/extras": "^1.17.0",
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "quasar": "^2.18.7",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vue3-google-signin": "^2.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@intlify/unplugin-vue-i18n": "^11.0.7",
    "@quasar/app-vite": "^2.5.2",
    "@quasar/cli": "^2.5.0",
    "@types/express": "^4.17.25",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite-plugin-checker": "^0.12.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "serialize-javascript": "^7.0.4"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.9.0"
  },
  "lint-staged": {
    "src/**/*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,scss,css}": [
      "prettier --write"
    ]
  }
}
